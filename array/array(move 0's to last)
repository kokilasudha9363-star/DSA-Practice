#include<iostream>
#include<vector>
using namespace std;
int main(){
    int n;
    cin>>n;
    vector<int>a(n);
    for(int i =0; i<n;i++){
        cin>>a[i];
    }
    
    int i=-1;
    for(int j=0;j<n;j++){
            if(a[j]==0){
                i=j;
                break;}}
     for(int j=i+1;j<n;j++){
            if(a[j]!=0){
                 swap(a[j],a[i]);
                 i++;}}
            
        
     for(int k=0;k<n;k++){
          cout<<a[k]<<" ";   
     }
   
    return 0;}
#include<iostream>
#include<vector>
using namespace std;
int main(){
    int n;
    cin>>n;
    vector<int>a(n);
    for(int i =1; i<=n;i++){
        cin>>a[i];
    }
    int sorted;
    for(int i=1;i<n;i++){
        if(a[i]<a[i-1]){
            sorted=false;
            break;}}
  
    if(sorted){
        cout<<"sorted";
    }
    else{
        cout<<"unsorted";}
    return 0;}
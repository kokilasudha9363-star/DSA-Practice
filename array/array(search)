#include<iostream>
using namespace std;

int main(){
    int a[] = {1,3,4,2,7};
    int n;
    cin >> n;

    int size = sizeof(a)/sizeof(a[0]);

    for(int i = 0; i < size; i++){
        if(a[i] == n){
            cout << "found";
            return 0;
        }
    }

    cout << "not found";
    return 0;
}
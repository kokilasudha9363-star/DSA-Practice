#include<iostream>
#include<vector>
using namespace std;
int main(){
    int n;
    cin>>n;
    if(n==0){
        return 0;}
    vector<int>a(n);
    for(int i=0;i<n;i++){
        cin>>a[i];}
    int d;
    cin>>d;
    d=d%n;
    vector<int>temp(d);
    for(int j=0;j<d;j++){
        temp[j]=a[j];
       }
    for(int i=d;i<n;i++){
         a[i-d]=a[i];}
     for(int i=n-d;i<n;i++){
         a[i]=temp[i-(n-d)];}
     for(int i=0;i<n;i++){
         cout<<a[i]<<" ";}
     return 0;}
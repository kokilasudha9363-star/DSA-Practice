class Solution {
  public:
    vector<int> getMinMax(vector<int> &arr) {
        
        int Max=arr[0];
        int Min=arr[0];
        for(int i=0;i<arr.size();i++){
            if(Max<arr[i]){
                Max=arr[i];
            }
        }
        for(int i=0;i<arr.size();i++){
            if(Min>arr[i]){
                Min=arr[i];}}
        return {Min,Max};
    }
};